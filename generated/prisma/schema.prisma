// ─────────────────────────────────────────────────────────────────────────────
// EasySLR — Prisma Schema
//
// Architecture: Two-level hierarchy
//   Organization → Project → Article
//
// Authorization model:
//   - Organization membership (OWNER / MEMBER) gates project access
//   - Project-level role (MANAGER / REVIEWER) gates per-project actions
//   - All authorization is enforced server-side in tRPC procedures
//
// Import system:
//   - ImportBatch: one record per uploaded file
//   - ImportRowResult: one record per row in the file (audit trail)
//   - Article: the imported article with its current state
//
// Why separate ImportRowResult from Article:
//   Articles are edited after import. ImportRowResult preserves what the engine
//   decided at import time. These are different concerns.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ORGANIZATION ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // URL-safe identifier: "johns-hopkins-lab"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  OrganizationMember[]
  projects Project[]

  @@index([slug])
}

// ─── ORGANIZATION MEMBERSHIP ─────────────────────────────────────────────────

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

enum OrgRole {
  OWNER // Can manage org settings, invite/remove members, delete org
  MEMBER // Can create and access projects within the org
}

// ─── PROJECT ──────────────────────────────────────────────────────────────────

model Project {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User            @relation("ProjectCreator", fields: [createdById], references: [id])
  members       ProjectMember[]
  articles      Article[]
  importBatches ImportBatch[]

  @@index([organizationId])
}

// ─── PROJECT MEMBERSHIP ───────────────────────────────────────────────────────

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(REVIEWER)
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

enum ProjectRole {
  MANAGER // Can import articles, manage project settings, add reviewers
  REVIEWER // Can view articles, make include/exclude decisions
}

// ─── ARTICLE ──────────────────────────────────────────────────────────────────

model Article {
  id        String   @id @default(cuid())
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Bibliographic fields
  pmid        String?
  doi         String?
  pmcid       String?
  nihmsId     String?
  title       String? @db.Text
  authors     String? @db.Text
  firstAuthor String?
  journal     String?
  pubYear     Int?
  citation    String? @db.Text
  createDate  String?

  // Priority level
  priority ArticlePriority @default(MEDIUM)

  // Import status — displayed as a badge in the article table
  importStatus ArticleImportStatus @default(IMPORTED)

  // Quality warnings from the import engine (array of Warning objects)
  importWarnings Json @default("[]")

  // Full conflict/correction context for researcher reference
  importNotes Json?

  // Review decision
  reviewStatus ReviewStatus @default(PENDING)
  reviewNote   String?      @db.Text
  reviewedById String?
  reviewedAt   DateTime?

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewedBy      User?            @relation("ArticleReviewer", fields: [reviewedById], references: [id])
  importRowResult ImportRowResult?

  // PMID must be unique within a project
  // CONFLICT articles have pmid=null to preserve this constraint
  @@unique([projectId, pmid])
  @@index([projectId])
  @@index([pmid])
  @@index([doi])
  @@index([reviewStatus])
  @@index([importStatus])
  @@index([priority])
}

enum ArticlePriority {
  HIGH
  MEDIUM
  LOW
}

enum ArticleImportStatus {
  IMPORTED
  AUTO_CORRECTED
  IMPORTED_WARNING
  POSSIBLE_MATCH
  LIKELY_DUPLICATE
  CONFLICT
}

enum ReviewStatus {
  PENDING
  INCLUDED
  EXCLUDED
  MAYBE
}

// ─── IMPORT BATCH ─────────────────────────────────────────────────────────────

model ImportBatch {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  fileName String
  fileSize Int

  totalRows                Int
  importedCount            Int
  autoCorrectedCount       Int
  importedWithWarningCount Int
  possibleMatchCount       Int
  likelyDuplicateCount     Int
  conflictCount            Int

  status ImportBatchStatus @default(COMPLETED)

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User              @relation("BatchUploader", fields: [userId], references: [id])
  rowResults ImportRowResult[]

  @@index([projectId])
  @@index([userId])
}

enum ImportBatchStatus {
  PROCESSING
  PENDING
  COMPLETED
  FAILED
}

// ─── IMPORT ROW RESULT ────────────────────────────────────────────────────────

model ImportRowResult {
  id        String  @id @default(cuid())
  batchId   String
  articleId String? @unique
  rowIndex  Int

  finalStatus  ArticleImportStatus
  decidingRule String

  // Full audit data as JSON
  originalData   Json
  corrections    Json  @default("[]")
  warnings       Json  @default("[]")
  inferred       Json  @default("[]")
  identityResult Json?

  explanation String @db.Text

  // Researcher's resolution for LIKELY_DUPLICATE and CONFLICT rows
  resolution   ConflictResolution?
  resolvedById String?
  resolvedAt   DateTime?

  batch      ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  article    Article?    @relation(fields: [articleId], references: [id])
  resolvedBy User?       @relation("ConflictResolver", fields: [resolvedById], references: [id])

  @@index([batchId])
  @@index([articleId])
}

enum ConflictResolution {
  SKIPPED
  IMPORT_ANYWAY
  CORRECTED
}

// ─── NEXT AUTH MODELS ─────────────────────────────────────────────────────────

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  // EasySLR relations
  orgMemberships     OrganizationMember[]
  projectMemberships ProjectMember[]
  createdProjects    Project[]            @relation("ProjectCreator")
  reviewedArticles   Article[]            @relation("ArticleReviewer")
  uploadedBatches    ImportBatch[]        @relation("BatchUploader")
  resolvedConflicts  ImportRowResult[]    @relation("ConflictResolver")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PendingRegistration {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  institution      String?
  organizationName String
  token            String   @unique
  expires          DateTime
  createdAt        DateTime @default(now())
}
